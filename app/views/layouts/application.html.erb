<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("meta.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="KomaClip">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="<%= Current.user ? "kc-body antialiased" : "bg-white text-zinc-950 antialiased" %>">
    <% if Current.user %>
      <div class="kc-shell">
        <nav class="kc-app-nav" aria-label="<%= t("navigation.primary") %>">
          <%= link_to dashboard_path, class: "kc-brand" do %>
            <span class="kc-brand-icon">K</span>
            <span>
              KomaClip
              <small><%= t("navigation.tagline") %></small>
            </span>
          <% end %>

          <div class="kc-nav-links">
            <%= link_to t("navigation.workspace"), dashboard_path, "aria-current": ("page" if %w[dashboard projects clips project_assets panels].include?(controller_name)) %>
            <%= link_to t("navigation.templates"), clip_templates_path, "aria-current": ("page" if controller_name == "clip_templates") %>
            <% if Current.user.admin? %>
              <%= link_to t("navigation.visual_lab"), visual_lab_path, "aria-current": ("page" if controller_name == "visual_lab") %>
            <% end %>
          </div>

          <div class="kc-nav-actions">
            <div class="kc-locale-tabs" aria-label="<%= t("navigation.language") %>">
              <% available_locales.each do |locale| %>
                <%= link_to locale_link_label(locale), localized_current_path(locale), "aria-current": (I18n.locale == locale ? "true" : nil) %>
              <% end %>
            </div>
            <%= button_to t("navigation.sign_out"), session_path, method: :delete, class: "kc-nav-ghost" %>
            <%= button_to t("navigation.new_clip"), projects_path, method: :post, class: "kc-nav-cta" %>
          </div>
        </nav>

        <%= yield %>
      </div>
    <% else %>
      <nav class="fixed right-4 top-4 z-50 flex overflow-hidden rounded-md border border-zinc-200 bg-white/90 text-xs font-semibold text-zinc-700 shadow-sm backdrop-blur">
        <% available_locales.each do |locale| %>
          <%= link_to locale_link_label(locale), localized_current_path(locale), class: [
            "px-3 py-2 hover:bg-zinc-50",
            ("bg-zinc-950 text-white hover:bg-zinc-900" if I18n.locale == locale)
          ].compact.join(" "), "aria-current": ("page" if I18n.locale == locale) %>
        <% end %>
      </nav>

      <%= yield %>
    <% end %>
  </body>
</html>
