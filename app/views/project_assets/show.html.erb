<main class="kc-main">
  <header class="kc-page-header">
    <div>
      <%= link_to t(".back"), project_path(id: @project), class: "kc-button-ghost" %>
      <h1 class="kc-title"><%= @asset.filename %></h1>
      <p class="kc-subtitle">
        <%= t(".meta", kind: t("project_asset_kinds.#{@asset.kind}"), size: number_to_human_size(@asset.byte_size), status: t("project_asset_statuses.#{@asset.status}")) %>
      </p>
    </div>
  </header>

  <% if flash[:alert] %>
    <div class="kc-flash kc-flash-alert"><%= flash[:alert] %></div>
  <% end %>

  <% if flash[:notice] %>
    <div class="kc-flash kc-flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <section class="kc-detail-grid">
    <div class="kc-panel kc-panel-pad">
      <div class="kc-shot-head">
        <div>
          <h2 class="kc-section-title"><%= t(".preview_title") %></h2>
          <p class="kc-muted mt-1"><%= @asset.content_type %></p>
        </div>
        <span class="kc-pill"><%= t("project_asset_statuses.#{@asset.status}") %></span>
      </div>

      <div class="kc-media-frame mt-5" data-controller="media-preview">
        <% if @asset.file.attached? %>
          <%= image_tag @asset.file, alt: @asset.filename, data: { media_preview_target: "image", action: "error->media-preview#fallback" } %>
          <p class="kc-media-empty" data-media-preview-target="fallback" hidden><%= t(".preview_empty") %></p>
        <% else %>
          <p class="kc-media-empty"><%= t(".preview_empty") %></p>
        <% end %>
      </div>
    </div>

    <aside class="kc-grid">
      <section class="kc-panel kc-panel-pad">
        <h2 class="kc-section-title"><%= t(".metadata_title") %></h2>

        <dl class="kc-meta-list mt-5">
          <div class="kc-meta-item">
            <dt><%= t(".content_type") %></dt>
            <dd><%= @asset.content_type %></dd>
          </div>
          <div class="kc-meta-item">
            <dt><%= t(".storage_key") %></dt>
            <dd><%= @asset.storage_key %></dd>
          </div>
          <div class="kc-meta-item">
            <dt><%= t(".uploaded") %></dt>
            <dd><%= l(@asset.created_at, format: :short) %></dd>
          </div>
          <div class="kc-meta-item">
            <dt><%= t(".checksum") %></dt>
            <dd><%= @asset.checksum %></dd>
          </div>
        </dl>
      </section>

      <section class="kc-panel kc-panel-pad">
        <h2 class="kc-section-title"><%= t(".actions_title") %></h2>
        <div class="mt-5 grid gap-3">
          <% if @asset.extractable_panel_source? %>
            <%= button_to t(".create_panel"), project_asset_panels_path(project_id: @project, asset_id: @asset), method: :post, class: "kc-button-primary w-full" %>
          <% end %>
          <%= link_to t(".download"), download_project_asset_path(project_id: @project, id: @asset), class: "kc-button w-full" %>
          <%= button_to t(".delete"), project_asset_path(project_id: @project, id: @asset), method: :delete, class: "kc-danger-button w-full" %>
        </div>
      </section>
    </aside>
  </section>
</main>
