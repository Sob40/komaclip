<main class="mx-auto flex min-h-screen max-w-md flex-col justify-center px-6 py-16">
  <h1 class="text-3xl font-bold tracking-tight text-zinc-950"><%= t(".title") %></h1>

  <%= tag.div(flash[:alert], class: "mt-6 rounded-md bg-red-50 p-3 text-sm text-red-700") if flash[:alert] %>

  <%= form_with url: password_path(token: params[:token]), method: :put, class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :password, t("forms.new_password"), class: "block text-sm font-medium text-zinc-900" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: t("forms.new_password_placeholder"), maxlength: 72, class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :password_confirmation, t("forms.repeat_new_password"), class: "block text-sm font-medium text-zinc-900" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: t("forms.repeat_new_password_placeholder"), maxlength: 72, class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2" %>
    </div>

    <%= form.submit t("forms.save"), class: "w-full rounded-md bg-zinc-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800" %>
  <% end %>
</main>
