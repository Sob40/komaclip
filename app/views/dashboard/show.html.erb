<main class="mx-auto max-w-6xl px-6 py-10">
  <header class="flex items-center justify-between gap-6">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-zinc-500">KomaClip</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-zinc-950"><%= t(".title") %></h1>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to t(".new_project"), new_project_path, class: "rounded-md bg-zinc-950 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800" %>
      <%= button_to t("navigation.sign_out"), session_path, method: :delete, class: "rounded-md border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-zinc-50" %>
    </div>
  </header>

  <% if flash[:notice] %>
    <div class="mt-8 rounded-md bg-green-50 p-3 text-sm text-green-700"><%= flash[:notice] %></div>
  <% end %>

  <section class="mt-10">
    <div class="flex items-end justify-between gap-6">
      <div>
        <h2 class="text-lg font-semibold text-zinc-950"><%= t(".projects_title") %></h2>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".projects_body") %></p>
      </div>
      <p class="text-sm font-semibold text-zinc-500"><%= t(".project_count", count: @projects.size) %></p>
    </div>

    <% if @projects.any? %>
      <div class="mt-6 overflow-hidden rounded-md border border-zinc-200">
        <table class="w-full text-left text-sm">
          <thead class="bg-zinc-50 text-xs font-semibold uppercase text-zinc-500">
            <tr>
              <th class="px-4 py-3"><%= t(".table.project") %></th>
              <th class="px-4 py-3"><%= t(".table.content_locale") %></th>
              <th class="px-4 py-3"><%= t(".table.status") %></th>
              <th class="px-4 py-3"><%= t(".table.updated") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-200">
            <% @projects.each do |project| %>
              <tr class="hover:bg-zinc-50">
                <td class="px-4 py-4 font-semibold text-zinc-950">
                  <%= link_to project.title, project_path(id: project), class: "underline" %>
                </td>
                <td class="px-4 py-4 text-zinc-600"><%= t("content_locales.#{project.content_locale}") %></td>
                <td class="px-4 py-4 text-zinc-600"><%= t("project_statuses.#{project.status}") %></td>
                <td class="px-4 py-4 text-zinc-600"><%= l(project.updated_at, format: :short) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="mt-6 rounded-lg border border-dashed border-zinc-300 p-8">
        <h3 class="text-lg font-semibold text-zinc-950"><%= t(".empty_title") %></h3>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".empty_body") %></p>
        <%= link_to t(".empty_action"), new_project_path, class: "mt-6 inline-block rounded-md bg-zinc-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800" %>
      </div>
    <% end %>
  </section>
</main>
