<main class="kc-main">
  <header class="kc-page-header">
    <div>
      <p class="kc-eyebrow"><%= t(".eyebrow") %></p>
      <h1 class="kc-title"><%= t(".title") %></h1>
      <p class="kc-subtitle"><%= t(".body") %></p>
    </div>

    <%= link_to t(".new_project"), new_project_path, class: "kc-button-primary" %>
  </header>

  <% if flash[:notice] %>
    <div class="kc-flash kc-flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <section id="material" class="kc-panel kc-panel-pad">
    <div class="kc-page-header">
      <div>
        <h2 class="kc-section-title"><%= t(".projects_title") %></h2>
        <p class="kc-subtitle"><%= t(".projects_body") %></p>
      </div>
      <span class="kc-pill"><%= t(".project_count", count: @projects.size) %></span>
    </div>

    <% if @projects.any? %>
      <div class="kc-table-wrap">
        <table class="kc-table">
          <thead>
            <tr>
              <th><%= t(".table.project") %></th>
              <th><%= t(".table.content_locale") %></th>
              <th><%= t(".table.status") %></th>
              <th><%= t(".table.updated") %></th>
            </tr>
          </thead>
          <tbody>
            <% @projects.each do |project| %>
              <tr>
                <td><%= link_to project.title, project_path(id: project) %></td>
                <td><%= t("content_locales.#{project.content_locale}") %></td>
                <td><span class="kc-pill kc-pill-warm"><%= t("project_statuses.#{project.status}") %></span></td>
                <td><%= l(project.updated_at, format: :short) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="kc-empty">
        <div>
          <h3 class="kc-section-title"><%= t(".empty_title") %></h3>
          <p class="kc-subtitle"><%= t(".empty_body") %></p>
          <%= link_to t(".empty_action"), new_project_path, class: "kc-button-primary mt-5" %>
        </div>
      </div>
    <% end %>
  </section>
</main>
