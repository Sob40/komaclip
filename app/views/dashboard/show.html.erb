<main class="mx-auto max-w-6xl px-6 py-10">
  <header class="flex items-center justify-between gap-6">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-zinc-500">KomaClip</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-zinc-950"><%= t(".title") %></h1>
    </div>
    <%= button_to t("navigation.sign_out"), session_path, method: :delete, class: "rounded-md border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-zinc-50" %>
  </header>

  <section class="mt-10 rounded-lg border border-dashed border-zinc-300 p-8">
    <h2 class="text-lg font-semibold text-zinc-950"><%= t(".foundation_title") %></h2>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600">
      <%= t(".foundation_body") %>
    </p>
  </section>
</main>
