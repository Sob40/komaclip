<main class="mx-auto flex min-h-screen max-w-md flex-col justify-center px-6 py-16">
  <%= tag.div(flash[:alert], class: "mb-4 rounded-md bg-red-50 p-3 text-sm text-red-700") if flash[:alert] %>

  <h1 class="text-3xl font-bold tracking-tight text-zinc-950"><%= t(".title") %></h1>

  <%= form_with model: @user, url: registration_path, class: "mt-8 space-y-5" do |form| %>
    <% if @user.errors.any? %>
      <div class="rounded-md bg-red-50 p-3 text-sm text-red-700">
        <%= @user.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= form.label :email_address, t("forms.email"), class: "block text-sm font-medium text-zinc-900" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :password, t("forms.password"), class: "block text-sm font-medium text-zinc-900" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", minlength: 12, maxlength: 72, class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :password_confirmation, t("forms.password_confirmation"), class: "block text-sm font-medium text-zinc-900" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", minlength: 12, maxlength: 72, class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2" %>
    </div>

    <%= form.hidden_field :locale, value: I18n.locale %>
    <%= form.submit t("navigation.create_account"), class: "w-full rounded-md bg-zinc-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800" %>
  <% end %>

  <p class="mt-6 text-sm text-zinc-600">
    <%= t(".already_have_account") %>
    <%= link_to t("navigation.sign_in"), new_session_path, class: "font-semibold text-zinc-950 underline" %>
  </p>
</main>
