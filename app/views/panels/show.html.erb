<main class="kc-main">
  <header class="kc-page-header">
    <div>
      <%= link_to t(".back"), project_path(id: @project), class: "kc-button-ghost" %>
      <h1 class="kc-title"><%= @panel.label %></h1>
      <p class="kc-subtitle">
        <%= t(".meta", position: @panel.position, source: @panel.project_asset.filename) %>
      </p>
    </div>
  </header>

  <% if flash[:notice] %>
    <div class="kc-flash kc-flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <section class="kc-detail-grid">
    <div class="kc-panel kc-panel-pad">
      <div class="kc-shot-head">
        <div>
          <h2 class="kc-section-title"><%= t(".preview_title") %></h2>
          <p class="kc-muted mt-1"><%= t(".source_asset") %> · <%= @panel.project_asset.filename %></p>
        </div>
        <span class="kc-pill"><%= t(".crop_unit") %>: <%= @panel.crop.fetch("unit") %></span>
      </div>

      <div class="kc-media-frame mt-5" data-controller="media-preview">
        <% if @panel.project_asset.file.attached? %>
          <%= image_tag @panel.project_asset.file, alt: @panel.label, data: { media_preview_target: "image", action: "error->media-preview#fallback" } %>
          <span class="kc-crop-outline" data-media-preview-target="overlay"></span>
          <p class="kc-media-empty" data-media-preview-target="fallback" hidden><%= t(".preview_empty") %></p>
        <% else %>
          <p class="kc-media-empty"><%= t(".preview_empty") %></p>
        <% end %>
      </div>
    </div>

    <aside class="kc-grid">
      <section class="kc-panel kc-panel-pad">
        <h2 class="kc-section-title"><%= t(".crop_title") %></h2>

        <dl class="kc-meta-list mt-5">
          <div class="kc-meta-item">
            <dt><%= t(".source_asset") %></dt>
            <dd>
              <%= link_to @panel.project_asset.filename, project_asset_path(project_id: @project, id: @panel.project_asset) %>
            </dd>
          </div>
          <div class="kc-meta-item">
            <dt><%= t(".crop_unit") %></dt>
            <dd><%= @panel.crop.fetch("unit") %></dd>
          </div>
          <div class="kc-meta-item">
            <dt><%= t(".crop_origin") %></dt>
            <dd><%= "#{@panel.crop.fetch("x")}, #{@panel.crop.fetch("y")}" %></dd>
          </div>
          <div class="kc-meta-item">
            <dt><%= t(".crop_size") %></dt>
            <dd><%= "#{@panel.crop.fetch("width")} x #{@panel.crop.fetch("height")}" %></dd>
          </div>
        </dl>
      </section>

      <section class="kc-panel kc-panel-pad">
        <h2 class="kc-section-title"><%= t(".actions_title") %></h2>
        <div class="mt-5">
          <%= button_to t(".delete"), project_panel_path(project_id: @project, id: @panel), method: :delete, class: "kc-danger-button w-full" %>
        </div>
      </section>
    </aside>
  </section>
</main>
