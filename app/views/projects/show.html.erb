<main class="mx-auto max-w-6xl px-6 py-10">
  <header class="flex items-start justify-between gap-6">
    <div>
      <%= link_to t("projects.show.back"), dashboard_path, class: "text-sm font-semibold text-zinc-600 underline" %>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-zinc-950"><%= @project.title %></h1>
      <p class="mt-2 text-sm leading-6 text-zinc-600">
        <%= t(".meta", content_locale: t("content_locales.#{@project.content_locale}"), status: t("project_statuses.#{@project.status}")) %>
      </p>
    </div>
    <%= button_to t("navigation.sign_out"), session_path, method: :delete, class: "rounded-md border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-zinc-50" %>
  </header>

  <section class="mt-10 grid gap-4 sm:grid-cols-4">
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".assets") %></p>
      <p class="mt-2 text-3xl font-bold text-zinc-950"><%= @project_assets.size %></p>
    </div>
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".panels") %></p>
      <p class="mt-2 text-3xl font-bold text-zinc-950"><%= @panels.size %></p>
    </div>
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".clips") %></p>
      <p class="mt-2 text-3xl font-bold text-zinc-950"><%= @clips_count %></p>
    </div>
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".renders") %></p>
      <p class="mt-2 text-3xl font-bold text-zinc-950"><%= @renders_count %></p>
    </div>
  </section>

  <section class="mt-10 rounded-lg border border-dashed border-zinc-300 p-8">
    <h2 class="text-lg font-semibold text-zinc-950"><%= t(".next_title") %></h2>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".next_body") %></p>
  </section>

  <% if flash[:alert] %>
    <div class="mt-8 rounded-md bg-red-50 p-3 text-sm text-red-700"><%= flash[:alert] %></div>
  <% end %>

  <% if flash[:notice] %>
    <div class="mt-8 rounded-md bg-green-50 p-3 text-sm text-green-700"><%= flash[:notice] %></div>
  <% end %>

  <section class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem]">
    <div>
      <div class="flex items-end justify-between gap-6">
        <div>
          <h2 class="text-lg font-semibold text-zinc-950"><%= t(".assets_title") %></h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".assets_body") %></p>
        </div>
      </div>

      <% if @project_assets.any? %>
        <div class="mt-6 overflow-hidden rounded-md border border-zinc-200">
          <table class="w-full text-left text-sm">
            <thead class="bg-zinc-50 text-xs font-semibold uppercase text-zinc-500">
              <tr>
                <th class="px-4 py-3"><%= t(".assets_table.file") %></th>
                <th class="px-4 py-3"><%= t(".assets_table.kind") %></th>
                <th class="px-4 py-3"><%= t(".assets_table.size") %></th>
                <th class="px-4 py-3"><%= t(".assets_table.status") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-200">
              <% @project_assets.each do |asset| %>
                <tr class="hover:bg-zinc-50">
                  <td class="px-4 py-4 font-semibold text-zinc-950">
                    <%= link_to asset.filename, project_asset_path(project_id: @project, id: asset), class: "underline" %>
                  </td>
                  <td class="px-4 py-4 text-zinc-600"><%= t("project_asset_kinds.#{asset.kind}") %></td>
                  <td class="px-4 py-4 text-zinc-600"><%= number_to_human_size(asset.byte_size) %></td>
                  <td class="px-4 py-4 text-zinc-600"><%= t("project_asset_statuses.#{asset.status}") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="mt-6 rounded-lg border border-dashed border-zinc-300 p-8">
          <h3 class="text-lg font-semibold text-zinc-950"><%= t(".assets_empty_title") %></h3>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".assets_empty_body") %></p>
        </div>
      <% end %>
    </div>

    <aside class="rounded-md border border-zinc-200 p-5">
      <h2 class="text-lg font-semibold text-zinc-950"><%= t(".upload_title") %></h2>
      <p class="mt-2 text-sm leading-6 text-zinc-600"><%= t(".upload_body") %></p>

      <%= form_with model: [ @project, ProjectAsset.new ], url: project_assets_path(project_id: @project), class: "mt-6 space-y-5" do |form| %>
        <div>
          <%= form.label :kind, t(".upload_kind"), class: "block text-sm font-medium text-zinc-900" %>
          <%= form.select :kind, project_asset_kind_options, {}, class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2" %>
        </div>

        <div>
          <%= form.label :file, t(".upload_file"), class: "block text-sm font-medium text-zinc-900" %>
          <%= form.file_field :file, required: true, accept: "image/jpeg,image/png,image/webp", class: "mt-2 w-full rounded-md border border-zinc-300 px-3 py-2 text-sm" %>
          <p class="mt-2 text-sm leading-6 text-zinc-600"><%= t(".upload_hint") %></p>
        </div>

        <%= form.submit t(".upload_submit"), class: "w-full rounded-md bg-zinc-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800" %>
      <% end %>
    </aside>
  </section>

  <section class="mt-10">
    <div>
      <h2 class="text-lg font-semibold text-zinc-950"><%= t(".panels_title") %></h2>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".panels_body") %></p>
    </div>

    <% if @panels.any? %>
      <div class="mt-6 overflow-hidden rounded-md border border-zinc-200">
        <table class="w-full text-left text-sm">
          <thead class="bg-zinc-50 text-xs font-semibold uppercase text-zinc-500">
            <tr>
              <th class="px-4 py-3"><%= t(".panels_table.position") %></th>
              <th class="px-4 py-3"><%= t(".panels_table.label") %></th>
              <th class="px-4 py-3"><%= t(".panels_table.source") %></th>
              <th class="px-4 py-3"><%= t(".panels_table.crop") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-200">
            <% @panels.each do |panel| %>
              <tr class="hover:bg-zinc-50">
                <td class="px-4 py-4 text-zinc-600"><%= panel.position %></td>
                <td class="px-4 py-4 font-semibold text-zinc-950">
                  <%= link_to panel.label, project_panel_path(project_id: @project, id: panel), class: "underline" %>
                </td>
                <td class="px-4 py-4 text-zinc-600"><%= panel.project_asset.filename %></td>
                <td class="px-4 py-4 text-zinc-600"><%= t(".full_page_crop") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="mt-6 rounded-lg border border-dashed border-zinc-300 p-8">
        <h3 class="text-lg font-semibold text-zinc-950"><%= t(".panels_empty_title") %></h3>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".panels_empty_body") %></p>
      </div>
    <% end %>
  </section>

  <section class="mt-10">
    <div class="flex items-end justify-between gap-6">
      <div>
        <h2 class="text-lg font-semibold text-zinc-950"><%= t(".clips_title") %></h2>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".clips_body") %></p>
      </div>
      <%= button_to t(".create_clip"), project_clips_path(project_id: @project), method: :post, class: "rounded-md bg-zinc-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800" %>
    </div>

    <% if @clips.any? %>
      <div class="mt-6 overflow-hidden rounded-md border border-zinc-200">
        <table class="w-full text-left text-sm">
          <thead class="bg-zinc-50 text-xs font-semibold uppercase text-zinc-500">
            <tr>
              <th class="px-4 py-3"><%= t(".clips_table.position") %></th>
              <th class="px-4 py-3"><%= t(".clips_table.title") %></th>
              <th class="px-4 py-3"><%= t(".clips_table.duration") %></th>
              <th class="px-4 py-3"><%= t(".clips_table.status") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-200">
            <% @clips.each do |clip| %>
              <tr class="hover:bg-zinc-50">
                <td class="px-4 py-4 text-zinc-600"><%= clip.position %></td>
                <td class="px-4 py-4 font-semibold text-zinc-950">
                  <%= link_to clip.title, project_clip_path(project_id: @project, id: clip), class: "underline" %>
                </td>
                <td class="px-4 py-4 text-zinc-600"><%= t(".duration_seconds", seconds: clip.duration_ms / 1000) %></td>
                <td class="px-4 py-4 text-zinc-600"><%= t("clip_statuses.#{clip.status}") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="mt-6 rounded-lg border border-dashed border-zinc-300 p-8">
        <h3 class="text-lg font-semibold text-zinc-950"><%= t(".clips_empty_title") %></h3>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-600"><%= t(".clips_empty_body") %></p>
      </div>
    <% end %>
  </section>
</main>
