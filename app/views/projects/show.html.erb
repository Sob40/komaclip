<main class="kc-main kc-editor-shell">
  <% if flash[:alert] %>
    <div class="kc-flash kc-flash-alert"><%= flash[:alert] %></div>
  <% end %>

  <% if flash[:notice] %>
    <div class="kc-flash kc-flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <div class="kc-workspace kc-project-flow <%= "is-material-ready" if @material_ready %> <%= "is-direction-ready" if @direction_ready %> <%= "is-proposal-ready" if @proposal_ready %>">
    <section id="material" class="kc-flow-step <%= "is-complete" if @material_ready %>" data-flow-step="material">
      <div class="kc-step-heading">
        <span class="kc-step-number">1</span>
        <div>
          <p class="kc-eyebrow"><%= t(".material_eyebrow") %></p>
          <h2><%= t(".material_title") %></h2>
          <p><%= t(".material_body") %></p>
        </div>
      </div>

      <% if @project.metadata["templateName"].present? %>
        <div class="kc-template-applied">
          <strong><%= t(".template_applied_title") %></strong>
          <span><%= t(".template_applied_body", name: @project.metadata["templateName"]) %></span>
        </div>
      <% end %>

      <%= form_with model: [ @project, ProjectAsset.new ], url: project_assets_path(project_id: @project), class: "kc-uploader-form", data: { controller: "auto-submit" } do |form| %>
        <section class="kc-uploader">
          <%= form.hidden_field :kind, value: "source_page" %>
          <%= form.file_field :files, multiple: true, required: true, accept: "image/jpeg,image/png,image/webp", class: "kc-uploader-input", data: { action: "change->auto-submit#submit" } %>
          <div class="kc-upload-copy">
            <strong><%= t(".drop_title") %></strong>
            <span><%= t(".drop_body") %></span>
          </div>
          <%= form.label :files, t(".choose_files"), class: "kc-button-primary kc-upload-pick" %>
          <noscript><%= form.submit t(".upload_submit"), class: "kc-button-primary" %></noscript>
        </section>
      <% end %>

      <% if @panels.any? %>
        <section class="kc-material-review" aria-label="<%= t(".review_label") %>">
          <div class="kc-material-review-heading">
            <div>
              <strong><%= t(".review_title") %></strong>
              <span><%= t(".review_body") %></span>
            </div>
          </div>

          <div class="kc-scene-grid" data-controller="scene-list" data-scene-list-reorder-url-value="<%= reorder_project_panels_path(project_id: @project) %>">
            <% @panels.each do |panel| %>
              <% asset = panel.project_asset %>
              <% scene_text = panel.scene_text %>
              <% scene_text_popover_id = "scene-text-#{panel.id}" %>
              <article class="kc-scene-card" draggable="true" data-scene-list-target="item" data-panel-id="<%= panel.id %>" data-scene-title-template="<%= t(".scene_title", position: "%{position}") %>" data-action="dragstart->scene-list#dragStart dragover->scene-list#dragOver drop->scene-list#drop dragend->scene-list#dragEnd">
                <button class="kc-drag-handle" type="button" title="<%= t(".drag_scene") %>" aria-label="<%= t(".drag_scene_with_position", position: panel.position) %>">⋮⋮</button>
                <button class="kc-scene-media" type="button" popovertarget="<%= scene_text_popover_id %>" title="<%= t(".scene_text_open") %>" aria-label="<%= t(".scene_text_open_for", position: panel.position) %>">
                  <% if asset.file.attached? %>
                    <%= image_tag asset.file, alt: panel.label, loading: "lazy" %>
                  <% else %>
                    <span><%= t(".scene_media_missing") %></span>
                  <% end %>
                  <span class="kc-scene-order"><%= panel.position %></span>
                  <% if scene_text.present? %>
                    <span class="kc-scene-text-preview"><%= scene_text %></span>
                  <% end %>
                </button>

                <div id="<%= scene_text_popover_id %>" class="kc-scene-popover" popover>
                  <%= form_with url: project_panel_path(project_id: @project, id: panel), method: :patch, class: "kc-scene-text-form" do %>
                    <div>
                      <%= label_tag "scene_text_#{panel.id}", t(".scene_text_label") %>
                      <span><%= t(".scene_text_hint", count: Panel::MAX_SCENE_TEXT_LENGTH) %></span>
                    </div>
                    <%= text_area_tag "panel[scene_text]", scene_text, id: "scene_text_#{panel.id}", maxlength: Panel::MAX_SCENE_TEXT_LENGTH, rows: 4, placeholder: t(".scene_text_placeholder") %>
                    <div class="kc-scene-popover-actions">
                      <button type="button" class="kc-scene-action" popovertarget="<%= scene_text_popover_id %>" popovertargetaction="hide"><%= t(".cancel") %></button>
                      <%= submit_tag t(".save_scene_text"), class: "kc-scene-action kc-scene-action-save" %>
                    </div>
                  <% end %>
                </div>

                <div class="kc-scene-copy">
                  <strong><%= t(".scene_title", position: panel.position) %></strong>
                  <small title="<%= asset.filename %>"><%= asset.filename %></small>
                </div>

                <div class="kc-scene-footer">
                  <div class="kc-scene-actions" aria-label="<%= t(".scene_actions") %>">
                    <button class="kc-scene-text-chip <%= "is-empty" if scene_text.blank? %>" type="button" popovertarget="<%= scene_text_popover_id %>"><%= scene_text.present? ? t(".scene_text_chip") : t(".scene_text_add") %></button>
                    <%= button_to "⧉", duplicate_project_panel_path(project_id: @project, id: panel), method: :post, class: "kc-scene-action kc-scene-action-icon", title: t(".duplicate_scene"), form: { "aria-label": t(".duplicate_scene") } %>
                    <%= button_to "×", project_panel_path(project_id: @project, id: panel), method: :delete, class: "kc-scene-action kc-scene-action-icon kc-scene-action-danger", title: t(".delete_scene"), form: { "aria-label": t(".delete_scene") } %>
                  </div>
                </div>
              </article>
            <% end %>
          </div>

          <div class="kc-material-continue-row">
            <div class="kc-material-ready-status"><%= t(".material_ready_status", ready: @panels.size, total: @panels.size) %></div>
            <%= button_to t(".continue_direction"), confirm_material_project_path(id: @project), method: :post, class: "kc-button-primary kc-material-ready-button" %>
          </div>
        </section>
      <% end %>
    </section>

    <% if @material_ready %>
      <section id="direction" class="kc-flow-step kc-direction-step <%= "is-complete" if @direction_ready %> is-direction-<%= @direction_stage %>" data-flow-step="direction">
        <div class="kc-step-heading">
          <span class="kc-step-number">2</span>
          <div>
            <p class="kc-eyebrow"><%= t(".direction_eyebrow") %></p>
            <h2><%= t(".direction_title") %></h2>
          </div>
        </div>

        <% if @direction_stage != "goal" %>
          <%= button_to choose_direction_project_path(id: @project), method: :post, params: { stage: "goal" }, class: "kc-direction-summary-button" do %>
            <span>
              <small><%= t(".direction_cards.goal_label") %></small>
              <strong><%= t(".direction_cards.goals.#{@direction.fetch("goal")}.title") %></strong>
            </span>
            <span><%= t(".change") %></span>
          <% end %>
        <% end %>

        <% if @direction_stage == "goal" %>
          <div class="kc-direction-stage">
            <div class="kc-direction-group-label"><%= t(".direction_cards.goal_label") %></div>
            <div class="kc-choice-grid kc-goal-choice-grid" aria-label="<%= t(".direction_cards.goal_label") %>">
              <% ProjectDirection.goal_options.each do |goal| %>
                <%= button_to choose_direction_project_path(id: @project), method: :post, params: { direction: { goal: goal } }, class: "kc-choice-card", data: { goal_choice: goal } do %>
                  <%= direction_goal_icon(goal) %>
                  <span class="kc-choice-copy">
                    <strong><%= t(".direction_cards.goals.#{goal}.title") %></strong>
                    <span><%= t(".direction_cards.goals.#{goal}.body") %></span>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @direction_stage == "ready" %>
          <%= button_to choose_direction_project_path(id: @project), method: :post, params: { stage: "style" }, class: "kc-direction-summary-button" do %>
            <span>
              <small><%= t(".direction_cards.style_label") %></small>
              <strong><%= t(".direction_cards.styles.#{@direction.fetch("style")}.title") %></strong>
            </span>
            <span><%= t(".change") %></span>
          <% end %>
        <% end %>

        <% if @direction_stage == "style" %>
          <div class="kc-direction-stage kc-direction-style-stage">
            <div class="kc-direction-stage-heading">
              <span class="kc-direction-group-label"><%= t(".direction_cards.style_label") %></span>
              <h3><%= t(".style_stage_title") %></h3>
              <small><%= t(".style_stage_body") %></small>
            </div>
            <div class="kc-choice-grid kc-style-choice-grid" aria-label="<%= t(".direction_cards.style_label") %>">
              <% ProjectDirection.style_options.each do |style| %>
                <%= button_to choose_direction_project_path(id: @project), method: :post, params: { direction: { style: style } }, class: "kc-choice-card", data: { style_choice: style } do %>
                  <%= direction_style_icon(style) %>
                  <span class="kc-choice-copy">
                    <strong><%= t(".direction_cards.styles.#{style}.title") %></strong>
                    <span><%= t(".direction_cards.styles.#{style}.body") %></span>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>
    <% end %>

    <% if @direction_ready && @direction_stage == "ready" %>
      <section id="proposal" class="kc-flow-step kc-proposal-step" data-flow-step="proposal">
        <div class="kc-step-heading">
          <span class="kc-step-number">3</span>
          <div>
            <p class="kc-eyebrow"><%= t(".proposal_eyebrow") %></p>
            <h2><%= t(".proposal_title") %></h2>
            <p><%= t(".proposal_body") %></p>
          </div>
        </div>

        <section class="kc-proposal-settings">
          <div class="kc-proposal-settings-heading">
            <strong><%= t(".proposal_settings_title") %></strong>
            <span><%= t(".proposal_settings_body") %></span>
          </div>
          <div class="kc-proposal-settings-grid">
            <label class="kc-proposal-field">
              <span><%= t(".proposal_fields.genre") %></span>
              <%= select_tag :proposal_genre, options_for_select([[ t(".proposal_options.genre.drama"), "drama" ]]), class: "kc-input" %>
            </label>
            <label class="kc-proposal-field">
              <span><%= t(".proposal_fields.scene_time") %></span>
              <%= select_tag :proposal_scene_time, options_for_select([[ t(".proposal_options.scene_time.auto"), "auto" ]]), class: "kc-input" %>
              <small><%= t(".proposal_hints.scene_time") %></small>
            </label>
            <label class="kc-proposal-field">
              <span><%= t(".proposal_fields.intensity") %></span>
              <%= select_tag :proposal_intensity, options_for_select([[ t(".proposal_options.intensity.balanced"), "balanced" ]]), class: "kc-input" %>
              <small><%= t(".proposal_hints.intensity") %></small>
            </label>
          </div>
        </section>

        <section class="kc-generate-panel">
          <% if @proposal_ready %>
            <%= link_to project_clip_path(project_id: @project, id: @latest_clip), class: "kc-button-primary kc-generate-button" do %>
              <%= kc_icon("wand") %>
              <%= t(".open_proposal") %>
            <% end %>
          <% else %>
            <%= button_to project_clips_path(project_id: @project), method: :post, class: "kc-button-primary kc-generate-button" do %>
              <%= kc_icon("wand") %>
              <%= t(".create_proposal") %>
            <% end %>
          <% end %>
        </section>
      </section>
    <% end %>
  </div>

  <aside class="kc-project-preview-pane">
    <div class="kc-phone-frame kc-project-phone">
      <div class="kc-phone-screen">
        <div class="kc-phone-placeholder">
          <strong>KomaClip</strong>
          <span><%= @proposal_ready ? t(".phone_ready") : t(".phone_empty") %></span>
        </div>
      </div>
    </div>
    <label class="kc-preview-output-field">
      <span><%= t(".output_view") %></span>
      <select class="kc-input">
        <option><%= t(".output_reels") %></option>
      </select>
    </label>
    <div class="kc-preview-actions">
      <button type="button" class="kc-button-primary"><%= t(".play") %></button>
      <button type="button" class="kc-button"><%= t(".music") %></button>
      <% if @proposal_ready %>
        <%= link_to t(".export"), project_clip_path(project_id: @project, id: @latest_clip), class: "kc-button" %>
      <% else %>
        <button type="button" class="kc-button" disabled><%= t(".export") %></button>
      <% end %>
    </div>
  </aside>
</main>
