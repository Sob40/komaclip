<main class="kc-main">
  <header class="kc-page-header">
    <div>
      <%= link_to t("projects.show.back"), dashboard_path, class: "kc-button-ghost" %>
      <h1 class="kc-title"><%= @project.title %></h1>
      <p class="kc-subtitle">
        <%= t(".meta", content_locale: t("content_locales.#{@project.content_locale}"), status: t("project_statuses.#{@project.status}")) %>
      </p>
    </div>
  </header>

  <section class="kc-stat-grid kc-stat-grid-4">
    <div class="kc-stat-card">
      <p class="kc-stat-label"><%= t(".assets") %></p>
      <p class="kc-stat-value"><%= @project_assets.size %></p>
    </div>
    <div class="kc-stat-card">
      <p class="kc-stat-label"><%= t(".panels") %></p>
      <p class="kc-stat-value"><%= @panels.size %></p>
    </div>
    <div class="kc-stat-card">
      <p class="kc-stat-label"><%= t(".clips") %></p>
      <p class="kc-stat-value"><%= @clips_count %></p>
    </div>
    <div class="kc-stat-card">
      <p class="kc-stat-label"><%= t(".renders") %></p>
      <p class="kc-stat-value"><%= @renders_count %></p>
    </div>
  </section>

  <section id="direction" class="kc-panel kc-panel-pad mt-5">
    <h2 class="kc-section-title"><%= t(".next_title") %></h2>
    <p class="kc-subtitle"><%= t(".next_body") %></p>
  </section>

  <% if flash[:alert] %>
    <div class="kc-flash kc-flash-alert"><%= flash[:alert] %></div>
  <% end %>

  <% if flash[:notice] %>
    <div class="kc-flash kc-flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <section id="material" class="kc-grid kc-grid-2 mt-8">
    <div class="kc-panel kc-panel-pad">
      <div class="kc-page-header">
        <div>
          <h2 class="kc-section-title"><%= t(".assets_title") %></h2>
          <p class="kc-subtitle"><%= t(".assets_body") %></p>
        </div>
      </div>

      <% if @project_assets.any? %>
        <div class="kc-table-wrap">
          <table class="kc-table">
            <thead>
              <tr>
                <th><%= t(".assets_table.file") %></th>
                <th><%= t(".assets_table.kind") %></th>
                <th><%= t(".assets_table.size") %></th>
                <th><%= t(".assets_table.status") %></th>
              </tr>
            </thead>
            <tbody>
              <% @project_assets.each do |asset| %>
                <tr>
                  <td><%= link_to asset.filename, project_asset_path(project_id: @project, id: asset) %></td>
                  <td><%= t("project_asset_kinds.#{asset.kind}") %></td>
                  <td><%= number_to_human_size(asset.byte_size) %></td>
                  <td><span class="kc-pill"><%= t("project_asset_statuses.#{asset.status}") %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="kc-empty">
          <div>
            <h3 class="kc-section-title"><%= t(".assets_empty_title") %></h3>
            <p class="kc-subtitle"><%= t(".assets_empty_body") %></p>
          </div>
        </div>
      <% end %>
    </div>

    <aside class="kc-panel kc-panel-pad">
      <h2 class="kc-section-title"><%= t(".upload_title") %></h2>
      <p class="kc-subtitle"><%= t(".upload_body") %></p>

      <%= form_with model: [ @project, ProjectAsset.new ], url: project_assets_path(project_id: @project), class: "mt-6 grid gap-5" do |form| %>
        <div class="kc-form-field">
          <%= form.label :kind, t(".upload_kind") %>
          <%= form.select :kind, project_asset_kind_options, {}, class: "kc-input" %>
        </div>

        <div class="kc-form-field">
          <%= form.label :file, t(".upload_file") %>
          <%= form.file_field :file, required: true, accept: "image/jpeg,image/png,image/webp", class: "kc-input py-2" %>
          <p class="kc-muted text-sm"><%= t(".upload_hint") %></p>
        </div>

        <%= form.submit t(".upload_submit"), class: "kc-button-primary w-full" %>
      <% end %>
    </aside>
  </section>

  <section class="kc-panel kc-panel-pad mt-8">
    <div>
      <h2 class="kc-section-title"><%= t(".panels_title") %></h2>
      <p class="kc-subtitle"><%= t(".panels_body") %></p>
    </div>

    <% if @panels.any? %>
      <div class="kc-table-wrap mt-6">
        <table class="kc-table">
          <thead>
            <tr>
              <th><%= t(".panels_table.position") %></th>
              <th><%= t(".panels_table.label") %></th>
              <th><%= t(".panels_table.source") %></th>
              <th><%= t(".panels_table.crop") %></th>
            </tr>
          </thead>
          <tbody>
            <% @panels.each do |panel| %>
              <tr>
                <td><%= panel.position %></td>
                <td><%= link_to panel.label, project_panel_path(project_id: @project, id: panel) %></td>
                <td><%= panel.project_asset.filename %></td>
                <td><%= t(".full_page_crop") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="kc-empty">
        <div>
          <h3 class="kc-section-title"><%= t(".panels_empty_title") %></h3>
          <p class="kc-subtitle"><%= t(".panels_empty_body") %></p>
        </div>
      </div>
    <% end %>
  </section>

  <section id="lab" class="kc-panel kc-panel-pad mt-8">
    <div class="kc-page-header">
      <div>
        <h2 class="kc-section-title"><%= t(".clips_title") %></h2>
        <p class="kc-subtitle"><%= t(".clips_body") %></p>
      </div>
      <%= button_to t(".create_clip"), project_clips_path(project_id: @project), method: :post, class: "kc-button-primary" %>
    </div>

    <% if @clips.any? %>
      <div class="kc-table-wrap">
        <table class="kc-table">
          <thead>
            <tr>
              <th><%= t(".clips_table.position") %></th>
              <th><%= t(".clips_table.title") %></th>
              <th><%= t(".clips_table.duration") %></th>
              <th><%= t(".clips_table.status") %></th>
            </tr>
          </thead>
          <tbody>
            <% @clips.each do |clip| %>
              <tr>
                <td><%= clip.position %></td>
                <td><%= link_to clip.title, project_clip_path(project_id: @project, id: clip) %></td>
                <td><%= t(".duration_seconds", seconds: clip.duration_ms / 1000) %></td>
                <td><span class="kc-pill kc-pill-warm"><%= t("clip_statuses.#{clip.status}") %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="kc-empty">
        <div>
          <h3 class="kc-section-title"><%= t(".clips_empty_title") %></h3>
          <p class="kc-subtitle"><%= t(".clips_empty_body") %></p>
        </div>
      </div>
    <% end %>
  </section>
</main>
