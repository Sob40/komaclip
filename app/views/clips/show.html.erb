<%= javascript_include_tag "clip_preview", "data-turbo-track": "reload", type: "module" %>

<main class="kc-main" data-controller="clip-preview">
  <script type="application/json" data-clip-preview-target="payload"><%= raw json_escape(JSON.generate(@preview_payload)) %></script>

  <header class="kc-page-header">
    <div>
      <%= link_to t(".back"), project_path(id: @project), class: "kc-button-ghost" %>
      <h1 class="kc-title"><%= @clip.title %></h1>
      <p class="kc-subtitle">
        <%= t(".meta", duration: @clip.duration_ms / 1000, status: t("clip_statuses.#{@clip.status}")) %>
      </p>
    </div>
  </header>

  <% if flash[:notice] %>
    <div class="kc-flash kc-flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <section class="kc-studio-grid">
    <div class="kc-grid">
      <section class="kc-stat-grid">
        <div class="kc-stat-card">
          <p class="kc-stat-label"><%= t(".cut_type") %></p>
          <p class="kc-stat-value"><%= t(".cut_type_value") %></p>
        </div>
        <div class="kc-stat-card">
          <p class="kc-stat-label"><%= t(".format") %></p>
          <p class="kc-stat-value"><%= t(".vertical_format_value") %></p>
        </div>
        <div class="kc-stat-card">
          <p class="kc-stat-label"><%= t(".panels") %></p>
          <p class="kc-stat-value"><%= @clip.scene_contract.fetch("shots").size %></p>
        </div>
      </section>

      <section class="kc-panel kc-panel-pad">
        <div class="kc-page-header">
          <div>
            <h2 class="kc-section-title"><%= t(".shots_title") %></h2>
            <p class="kc-subtitle"><%= t(".preview_body") %></p>
          </div>
          <span class="kc-pill"><%= @clip.scene_contract.fetch("shots").size %> <%= t(".panels") %></span>
        </div>

        <div class="kc-shot-list">
          <% @clip.scene_contract.fetch("shots").each do |shot| %>
            <article class="kc-shot">
              <div class="kc-shot-head">
                <h3 class="kc-section-title"><%= shot.fetch("label") %></h3>
                <span class="kc-pill kc-pill-warm"><%= t(".duration_seconds", seconds: shot.fetch("durationMs") / 1000) %></span>
              </div>
              <p class="kc-muted mt-2">
                <%= t(".shots_table.position") %> <%= shot.fetch("position") %> · <%= shot.fetch("filename") %>
              </p>
            </article>
          <% end %>
        </div>
      </section>

      <section class="kc-panel kc-panel-pad">
        <h2 class="kc-section-title"><%= t(".preview_details_title") %></h2>
        <div class="kc-stat-grid mt-5">
          <div class="kc-stat-card">
            <p class="kc-stat-label"><%= t("projects.show.direction_cards.goal_label") %></p>
            <p class="kc-stat-value"><%= t("projects.show.direction_cards.goals.#{@direction.fetch("goal")}.title") %></p>
            <p class="kc-muted mt-2"><%= t("projects.show.direction_cards.goals.#{@direction.fetch("goal")}.body") %></p>
          </div>
          <div class="kc-stat-card">
            <p class="kc-stat-label"><%= t("projects.show.direction_cards.style_label") %></p>
            <p class="kc-stat-value"><%= t("projects.show.direction_cards.styles.#{@direction.fetch("style")}.title") %></p>
            <p class="kc-muted mt-2"><%= t("projects.show.direction_cards.styles.#{@direction.fetch("style")}.body") %></p>
          </div>
          <div class="kc-stat-card">
            <p class="kc-stat-label"><%= t("projects.show.direction_cards.format_label") %></p>
            <p class="kc-stat-value"><%= t("projects.show.direction_cards.formats.#{@direction.fetch("format")}.title") %></p>
            <p class="kc-muted mt-2"><%= t("projects.show.direction_cards.formats.#{@direction.fetch("format")}.body") %></p>
          </div>
        </div>
        <div class="mt-6">
          <%= button_to t(".delete"), project_clip_path(project_id: @project, id: @clip), method: :delete, class: "kc-danger-button" %>
        </div>
      </section>
    </div>

    <aside class="kc-preview-pane">
      <section class="kc-panel kc-panel-pad">
        <div class="kc-shot-head">
          <div>
            <h2 class="kc-section-title"><%= t(".preview_title") %></h2>
            <p class="kc-muted mt-1"><%= t(".vertical_preview_note") %></p>
          </div>
          <span data-clip-preview-target="status" class="kc-pill">-</span>
        </div>

        <div class="kc-phone-frame">
          <div class="kc-phone-screen">
            <div data-clip-preview-target="stage" class="kc-phone-stage"></div>
          </div>
        </div>

        <div class="kc-preview-controls">
          <button type="button" data-action="clip-preview#previousShot" class="kc-button-ghost">
            <%= t(".previous_shot") %>
          </button>
          <button type="button" data-action="clip-preview#nextShot" class="kc-button-primary">
            <%= t(".next_shot") %>
          </button>
        </div>

        <div class="mt-4">
          <%= button_to t(".save_template"), clip_templates_path, method: :post, params: { clip_id: @clip.id }, class: "kc-button w-full" %>
        </div>
      </section>
    </aside>
  </section>
</main>
