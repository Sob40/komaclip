<main class="mx-auto max-w-5xl px-6 py-10">
  <header class="flex items-start justify-between gap-6">
    <div>
      <%= link_to t(".back"), project_path(id: @project), class: "text-sm font-semibold text-zinc-600 underline" %>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-zinc-950"><%= @clip.title %></h1>
      <p class="mt-2 text-sm leading-6 text-zinc-600">
        <%= t(".meta", duration: @clip.duration_ms / 1000, status: t("clip_statuses.#{@clip.status}")) %>
      </p>
    </div>
    <%= button_to t("navigation.sign_out"), session_path, method: :delete, class: "rounded-md border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-zinc-50" %>
  </header>

  <% if flash[:notice] %>
    <div class="mt-8 rounded-md bg-green-50 p-3 text-sm text-green-700"><%= flash[:notice] %></div>
  <% end %>

  <section class="mt-10 grid gap-4 sm:grid-cols-4">
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".renderer") %></p>
      <p class="mt-2 text-lg font-bold text-zinc-950"><%= @clip.scene_contract.fetch("renderer") %></p>
    </div>
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".format") %></p>
      <p class="mt-2 text-lg font-bold text-zinc-950">
        <%= "#{@clip.scene_contract.dig("format", "width")}x#{@clip.scene_contract.dig("format", "height")}" %>
      </p>
    </div>
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".fps") %></p>
      <p class="mt-2 text-lg font-bold text-zinc-950"><%= @clip.scene_contract.dig("format", "fps") %></p>
    </div>
    <div class="rounded-md border border-zinc-200 p-4">
      <p class="text-sm font-semibold text-zinc-500"><%= t(".shots") %></p>
      <p class="mt-2 text-lg font-bold text-zinc-950"><%= @clip.scene_contract.fetch("shots").size %></p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-lg font-semibold text-zinc-950"><%= t(".shots_title") %></h2>
    <div class="mt-6 overflow-hidden rounded-md border border-zinc-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-zinc-50 text-xs font-semibold uppercase text-zinc-500">
          <tr>
            <th class="px-4 py-3"><%= t(".shots_table.position") %></th>
            <th class="px-4 py-3"><%= t(".shots_table.label") %></th>
            <th class="px-4 py-3"><%= t(".shots_table.file") %></th>
            <th class="px-4 py-3"><%= t(".shots_table.duration") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-200">
          <% @clip.scene_contract.fetch("shots").each do |shot| %>
            <tr>
              <td class="px-4 py-4 text-zinc-600"><%= shot.fetch("position") %></td>
              <td class="px-4 py-4 font-semibold text-zinc-950"><%= shot.fetch("label") %></td>
              <td class="px-4 py-4 text-zinc-600"><%= shot.fetch("filename") %></td>
              <td class="px-4 py-4 text-zinc-600"><%= t(".duration_seconds", seconds: shot.fetch("durationMs") / 1000) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10 rounded-md border border-zinc-200 p-5">
    <h2 class="text-lg font-semibold text-zinc-950"><%= t(".contract_title") %></h2>
    <pre class="mt-4 overflow-auto rounded-md bg-zinc-950 p-4 text-xs leading-6 text-white"><%= JSON.pretty_generate(@clip.scene_contract) %></pre>
    <div class="mt-6">
      <%= button_to t(".delete"), project_clip_path(project_id: @project, id: @clip), method: :delete, class: "rounded-md border border-red-700 px-4 py-2.5 text-sm font-semibold text-red-700 hover:bg-red-50" %>
    </div>
  </section>
</main>
